# Mikrotik Traffic Monitor configuration

# Define one or more Mikrotik devices to monitor.
# Interfaces are auto-discovered via SNMP — no need to list them here.
# Each device can use SNMPv2c or SNMPv3 (default: v3).
devices:
  # SNMPv3 device (default — requires username, auth_pass, priv_pass)
  - name: "router-1"
    host: "192.168.88.1"
    port: 161
    # snmp_version: "v3"  # default, can be omitted
    username: "monitor"
    auth_pass: "your-auth-password"
    priv_pass: "your-priv-password"
    # auth_protocol: "sha1"   # "sha1" (default) or "sha256"
    # priv_protocol: "aes"    # "aes" (default) or "des"

  # SNMPv2c device (requires community string)
  # - name: "switch-1"
  #   host: "192.168.88.2"
  #   snmp_version: "v2c"
  #   community: "public"

# How often to poll SNMP counters (Go duration string).
poll_interval: "5s"

# Number of samples to keep in the ring buffer per interface.
ring_buffer_size: 240

# HTTP listen address for the dashboard.
listen_addr: ":8080"
